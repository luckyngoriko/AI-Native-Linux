# AI-OS.NET Kernel Configuration
# Revision 4 — Bootable Distribution
# Base: Linux LTS 6.12
#
# This config enables every kernel-level security primitive the AIOS
# constitutional core depends on: SELinux MAC, TPM2 attestation,
# IMA/EVM file integrity, dm-verity immutable rootfs verification,
# Linux namespaces for container isolation, WireGuard for fleet mesh,
# and the mandatory access control infrastructure for the 25-crate
# capability runtime.
#
# Modules marked =y are built into the kernel image (mandatory for
# early boot attestation). Modules marked =m are loadable for hardware
# support flexibility across diverse bare-metal targets.
#
# CMDLINE (reference):
#   selinux=1 security=selinux ima_appraise=enforce ima_policy=tcb
#   integrity=1 lockdown=confidentiality module.sig_enforce=1 quiet
#
# =====================================================================

#
# Architecture / Processor type and features (x86_64)
#
# S1.1 — Target x86_64 (AMD64) as the primary AIOS architecture.
# SMP required for multi-core scheduling across all 6 planes.
#
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_INSTRUCTION_DECODER=y
CONFIG_OUTPUT_FORMAT="elf64-x86-64"
CONFIG_ARCH_MMAP_RND_BITS_MAX=32
CONFIG_ARCH_MMAP_RND_COMPAT_BITS_MAX=16
CONFIG_NR_CPUS=256
CONFIG_SCHED_MC=y
CONFIG_SCHED_CLUSTER=y
CONFIG_X86_X2APIC=y
CONFIG_HYPERVISOR_GUEST=y

#
# S1.2 — PREEMPT low-latency: responsive runtime for capability
# enforcement without the unbounded latencies of full RT.
#
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_RT is not set
CONFIG_SMP=y
CONFIG_SCHED_SMT=y
CONFIG_SCHED_MC=y
CONFIG_NUMA=y
CONFIG_AMD_NUMA=y
CONFIG_X86_64_ACPI_NUMA=y
CONFIG_NODES_SHIFT=6

#
# S1.3 — Intel / AMD microcode loading (for spectre/meltdown mitigation
# updates at early boot, before any userspace runs).
#
CONFIG_MICROCODE=y
CONFIG_MICROCODE_INTEL=y
CONFIG_MICROCODE_AMD=y
CONFIG_MICROCODE_LATE_LOADING=y

CONFIG_X86_MSR=y
CONFIG_X86_CPUID=y
CONFIG_ACPI=y
CONFIG_ACPI_FAN=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_THERMAL=y
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_DMI=y
CONFIG_DMI_SYSFS=y

#
# S1.4 — Hardened profile: no 32-bit compatibility, no /dev/mem,
# no /dev/kmem (prevents DMA attacks from userspace).
#
# CONFIG_IA32_EMULATION is not set
# CONFIG_X86_X32 is not set
# CONFIG_DEVMEM is not set
# CONFIG_DEVKMEM is not set
CONFIG_STRICT_DEVMEM=y

# S1.5 — Kernel address space layout randomization (KASLR)
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_RANDOMIZE_MEMORY_PHYSICAL_PADDING=0xa

# S1.6 — Page table isolation (Meltdown mitigation)
CONFIG_PAGE_TABLE_ISOLATION=y

# S1.7 — Speculation mitigations
CONFIG_SPECULATION_MITIGATIONS=y
CONFIG_RETPOLINE=y
CONFIG_CPU_IBRS_ENTRY=y
CONFIG_CPU_IBPB_ENTRY=y
CONFIG_CPU_SRSO=y

