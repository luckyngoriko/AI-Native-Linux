[Unit]
Description=AI-OS.NET Ollama Local Inference Server
Documentation=https://ai-os.net/docs/ollama
After=network.target aios-vault-broker.service
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/bin/ollama serve
Environment=OLLAMA_HOST=127.0.0.1:11434
Environment=OLLAMA_MODELS=/var/lib/aios/models/ollama
Environment=OLLAMA_KEEP_ALIVE=24h
Environment=OLLAMA_NUM_PARALLEL=4
Environment=OLLAMA_MAX_LOADED_MODELS=3
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths=/var/lib/aios/models/ollama /run/ollama
NoNewPrivileges=yes
MemoryMax=80%
CPUQuota=600%
IPAccounting=yes

[Install]
WantedBy=multi-user.target
