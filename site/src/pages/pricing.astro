---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Revision 2 - AI-OS.NET"
  description="AI-OS.NET is currently in Revision 2 specification. Public commercial pricing is not published."
>
  <section class="mx-auto max-w-content px-8 py-24 text-center">
    <div class="animate inline-block rounded-badge bg-[rgba(206,40,103,0.08)] px-3 py-1.5">
      <span class="font-body text-[11px] font-medium text-[#ce2867]">Moved</span>
    </div>
    <h1 class="animate mt-6 font-heading text-[40px] font-bold text-[var(--text)]" style="animation-delay:100ms">
      AI-OS.NET is in Revision 2 specification.
    </h1>
    <p class="animate mx-auto mt-4 max-w-narrow font-body text-[16px] leading-relaxed text-[var(--muted)]" style="animation-delay:200ms">
      The old pricing page has been removed. The active public page is the Revision 2 specification.
    </p>
    <div class="animate mt-8" style="animation-delay:300ms">
      <a href="/roadmap" class="btn btn-hero btn-primary no-underline">Open Revision 2</a>
    </div>
  </section>
</BaseLayout>
