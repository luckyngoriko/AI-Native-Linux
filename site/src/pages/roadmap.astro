---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const phases = [
  {
    name: 'Revision 2 Contract Pack',
    status: 'Current',
    items: ['11 layers L0-L10 + XX cross-cutting', '53 contract-grade sub-specs', '24 constitutional invariants', '52,000+ specification lines', 'INV-002 enforced at 6 mechanical sites'],
  },
  {
    name: 'Closed Vocabularies',
    status: 'Locked',
    items: ['427 RecordTypes (S3.1 master enum)', '32 PropertyTypes (S2.4 verification)', 'Pinned IDs, additive evolution only', 'Reject-on-unknown across IDL surface'],
  },
  {
    name: 'Wave Consolidations',
    status: 'Closed',
    items: ['W1-W4 contract drafting', 'W5/W6/W7/W8 cross-layer reconciliation', 'W10/W13 IDL roll-up sweeps', 'W13: 22 → 428 RecordType entries'],
  },
  {
    name: 'Tier 5 Audit',
    status: 'Near-converged',
    items: ['9 read-only audit/simulation agents', 'SIM-D zero-findings on constitutional invariants', 'Mechanical drift map maintained', 'No silent narrative-vs-IDL gaps'],
  },
  {
    name: 'Reference System App',
    status: 'Validated',
    items: ['ProxGuard convergence reviewed', '6 alignment matches confirmed', 'AI-optional, advisory-only', 'Append-only sim.evidence_pack + prod.audit_event'],
  },
  {
    name: 'Implementation Phase',
    status: 'Next',
    items: ['L1 boot-recovery substrate first', 'L2 AIOS-FS userspace store', 'L3 SGR + L4 Policy Kernel', 'Per-spec MVP gate (E2 build, E3 tests)'],
  },
];

const decisions = [
  { title: 'Catalog-bound cognition', desc: 'The Capability Translator is a compiler over known capability manifests, not a prompt-to-shell system.' },
  { title: 'Fast path is still safe', desc: 'Latency tiers can bypass large models, but they cannot bypass typed actions, policy, verification, or evidence.' },
  { title: 'Userspace-first AIOS-FS', desc: 'AIOS-FS starts as an authoritative userspace object store with FUSE and portal projections; kernel work is deferred.' },
  { title: 'Default-deny policy', desc: 'The Policy Kernel uses hard denies, exact request approvals, simulation, and evidence-linked decisions.' },
  { title: 'Verification as grammar', desc: 'Success is typed and checked through 32 typed PropertyTypes such as service.active, package.installed, http.ok, and evidence.exists.' },
  { title: 'Most-restrictive sandbox', desc: 'Sandbox composition merges adapter defaults, app manifests, user hints, policy, and runtime floors toward stricter profiles.' },
  { title: 'INV-002 has six sites', desc: 'AI proposes, never executes is mechanically enforced across six concrete code sites, not stated as a single principle.' },
  { title: 'Evidence is append-only', desc: 'AI agents cannot modify evidence logs. Closed enums reject unknown values across the entire IDL surface.' },
  { title: 'Recovery without cognition', desc: 'L1 boot and recovery never depend on L5 LLM availability. The machine recovers offline, then layers cognition on top.' },
];

const deferred = [
  'A new kernel from scratch.',
  'A full RTOS replacement for the desktop.',
  'Unverified 100/100 security claims.',
  'AI modifying low-level infrastructure without evidence and rollback.',
  'A separate web admin panel that diverges from KDE state.',
  'Open-vocabulary fields in the IDL — every typed surface stays closed-enum.',
];

const files = [
  'L0_Governance_Evidence_Safety/01_status_evidence_taxonomy.md',
  'XX_Cross_Cutting/01_action_envelope_lifecycle.md',
  'L5_Cognitive_Core/02_capability_translator.md',
  'L5_Cognitive_Core/03_latency_tiering.md',
  'L2_AIOS_FS/01_object_model.md',
  'L2_AIOS_FS/02_query_view_language.md',
  'L2_AIOS_FS/03_conflict_resolution.md',
  'L2_AIOS_FS/04_implementation_space.md',
  'L2_AIOS_FS/05_namespace_layout.md',
  'L3_AIOS_SGR_Service_Graph_Runtime/03_capability_runtime_grpc.md',
  'L3_AIOS_SGR_Service_Graph_Runtime/04_adapter_model.md',
  'L4_Policy_Identity_Vault/01_policy_kernel.md',
  'L4_Policy_Identity_Vault/02_vault_broker.md',
  'L9_Observability_Admin_Operations/01_evidence_log.md',
  'L9_Observability_Admin_Operations/02_verification_grammar.md',
  'L6_Apps_Packages_Compatibility/04_sandbox_composition.md',
  'XX_Cross_Cutting/02_proxguard_reference_model.md',
];

const waves = [
  { wave: 'W1-W4', title: 'Contract drafting', what: 'Initial sub-specs per layer, ADR-style decision log, agent-readable boundaries.' },
  { wave: 'W5', title: 'Lifecycle reconciliation', what: 'Action envelope flow harmonized across L3, L4, L9 — single canonical lifecycle.' },
  { wave: 'W6', title: 'Vault & secrets', what: 'Secrets-as-capabilities locked. Raw secret read by AI agents is a hard deny.' },
  { wave: 'W7', title: 'Sandbox composition', what: 'Most-restrictive merge across adapter / manifest / user / policy / runtime floors.' },
  { wave: 'W8', title: 'Verification grammar', what: '32 PropertyTypes promoted to closed enum. service.active, http.ok, evidence.exists.' },
  { wave: 'W10', title: 'IDL roll-up I', what: 'Cross-layer enum alignment. Identifier discipline. Stable IDs preserved.' },
  { wave: 'W13', title: 'IDL roll-up II', what: '427 RecordType entries promoted. Documented narrative drift in §29.5.' },
];
---

<BaseLayout
  title="Roadmap - AI-OS.NET"
  description="AI-OS.NET Revision 2 specification: 53 contract-grade sub-specs across 11 layers, 24 invariants, 427 closed-enum record types, INV-002 enforced at 6 mechanical sites."
>
  <div class="mx-auto max-w-content px-8 py-16">
    <div class="text-center">
      <div class="animate inline-block rounded-badge bg-[rgba(206,40,103,0.08)] px-3 py-1.5">
        <span class="font-body text-[11px] font-medium text-[#ce2867]">Specification Revision 2</span>
      </div>
      <h1 class="animate mt-6 font-heading text-[40px] font-bold text-[var(--text)] md:text-[52px]" style="animation-delay:100ms">
        Contract-grade OS logic<br />before implementation.
      </h1>
      <p class="animate mt-4 max-w-narrow mx-auto font-body text-[18px] leading-relaxed text-[var(--muted)]" style="animation-delay:200ms">
        Revision 2 closes the architectural logic as an agent-readable contract pack: 53 sub-specs, 24 invariants, 427 closed-enum record types, and 32 typed verification properties — locked before the first line of OS code is written.
      </p>
    </div>

    <section class="mt-20">
      <SectionDivider label="REVISION 2 STRUCTURE" />
      <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
        {phases.map((phase, i) => (
          <div class={`card card-lg animate stagger-${i + 1}`}>
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-heading text-[20px] font-semibold text-[var(--text)]">{phase.name}</h2>
              <span class="rounded-badge bg-[rgba(206,40,103,0.08)] px-2 py-1 font-mono text-[11px] text-[var(--accent)]">{phase.status}</span>
            </div>
            <ul class="mt-6 flex flex-col gap-2.5">
              {phase.items.map(item => (
                <li class="flex items-start gap-2 font-body text-[13px] leading-relaxed text-[var(--muted)]">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--accent)]"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="WAVE CONSOLIDATIONS" />
      <p class="mt-4 max-w-narrow font-body text-[14px] leading-relaxed text-[var(--muted)]">
        Each wave reconciled the spec across multiple layers in a single deliberate pass. Drift is closed mechanically, not narratively.
      </p>
      <div class="mt-8 overflow-hidden rounded-[8px] border border-[var(--border)] bg-[var(--surface-1)]">
        <div class="grid grid-cols-[110px_1fr_2fr] gap-4 border-b border-[var(--border)] px-6 py-3">
          <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-[var(--muted)]">Wave</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-[var(--muted)]">Title</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-[var(--muted)]">Outcome</span>
        </div>
        {waves.map(w => (
          <div class="grid grid-cols-[110px_1fr_2fr] gap-4 border-b border-[var(--border)] px-6 py-3 last:border-b-0">
            <span class="font-mono text-[12px] text-[var(--accent)]">{w.wave}</span>
            <span class="font-body text-[13px] font-medium text-[var(--text)]">{w.title}</span>
            <span class="font-body text-[13px] leading-relaxed text-[var(--muted)]">{w.what}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="DECISIONS LOCKED IN REVISION 2" />
      <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {decisions.map((decision, i) => (
          <div class={`card animate stagger-${(i % 6) + 1}`}>
            <h2 class="font-heading text-[16px] font-semibold text-[var(--text)]">{decision.title}</h2>
            <p class="mt-2 font-body text-[13px] leading-relaxed text-[var(--muted)]">{decision.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="CANONICAL CONTRACT FILES" />
      <div class="mt-8 rounded-[8px] border border-[var(--border)] bg-[var(--surface-1)] p-6 md:p-8">
        <ul class="grid grid-cols-1 gap-2 md:grid-cols-2">
          {files.map(file => (
            <li class="font-mono text-[11px] leading-relaxed text-[var(--muted)]">{file}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="REFERENCE EXECUTION CONTRACT" />
      <div class="mt-8 rounded-[8px] border border-[var(--border)] bg-[var(--surface-1)] p-6 md:p-8">
        <pre class="whitespace-pre-wrap font-mono text-[12px] leading-relaxed text-[var(--muted)]">User: "restart nginx and verify the site"

Cognitive Core:
  - routes through latency tier
  - translates intent through capability catalog
  - produces ActionEnvelope.request

Policy Kernel:
  - evaluates exact request hash
  - allow / approval / deny

Capability Runtime:
  - restarts nginx through adapter
  - applies sandbox profile
  - verifies service.active
  - appends evidence receipts</pre>
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="REFERENCE SYSTEM APP" />
      <div class="mt-8 rounded-[8px] border border-[var(--border)] bg-[var(--surface-1)] p-6 md:p-8">
        <pre class="whitespace-pre-wrap font-mono text-[12px] leading-relaxed text-[var(--muted)]">ProxGuard:
  - installs as /aios/apps/proxguard
  - exposes proxguard.service.*, proxguard.dns.*, proxguard.gateway.*, proxguard.audit.*
  - keeps private app state
  - uses AIOS Vault Broker for provider credentials
  - asks L8 before public exposure
  - emits AIOS evidence receipts
  - never bypasses AIOS policy</pre>
      </div>
    </section>

    <section class="mt-20">
      <SectionDivider label="DEFERRED BY DESIGN" />
      <div class="mt-8 grid grid-cols-1 gap-3 md:grid-cols-2">
        {deferred.map((item, i) => (
          <div class={`animate stagger-${i + 1} rounded-[8px] border border-[var(--border)] bg-[var(--surface-1)] p-4`}>
            <p class="font-body text-[13px] leading-relaxed text-[var(--muted)]">{item}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
