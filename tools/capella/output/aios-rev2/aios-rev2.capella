        <ownedCapabilityRealizations xsi:type="org.polarsys.capella.core.data.la:CapabilityRealization"
            id="f2f5a66c-56bf-5853-928e-c8ba1896f993" name="S9.2 — First-Boot Flow (Rev.2)"
            description="&lt;p>&lt;strong>Layer.&lt;/strong> L1&lt;/p>&lt;p>&lt;strong>Status.&lt;/strong> REAL (initial; written 2026-05-09; E1 evidence — file exists; structural contract complete)&lt;/p>&lt;p>&lt;strong>Schema package.&lt;/strong> aios.firstboot.v1alpha1&lt;/p>&lt;p>&lt;strong>Source.&lt;/strong> L1_Kernel_Bootstrap_Recovery/02_first_boot_flow.md&lt;/p>">
          <ownedScenarios xsi:type="org.polarsys.capella.core.data.interaction:Scenario"
              id="4dca6e53-90d4-47fd-90da-691a7ede70bc" name="First-boot provisioning — FIRST_BOOT mode discipline"
              description="&lt;p>&lt;strong>Source:&lt;/strong> S9.2 First-Boot Flow (Rev.2)&lt;/p>&lt;p>&lt;strong>Participants:&lt;/strong> LOCAL_OPERATOR _system:local:operator-1, firstboot-coordinator (SERVICE), installer, vault-init, identity-init, policy-compiler, AIOS-FS, Vault Broker (S5.2), Identity Service (S5.1).&lt;/p>&lt;p>&lt;strong>Flow:&lt;/strong>&lt;/p>&lt;ol>&lt;li>Recovery image first mount; RecoveryMode = FIRST_BOOT (S9.1 W9)&lt;/li>&lt;li>firstboot-coordinator authenticated via hardware-key at console&lt;/li>&lt;li>installer initialises /aios filesystem layout per S4.1 namespace catalog&lt;/li>&lt;li>vault-init generates Ed25519 vault root key; uses one-shot BOOTSTRAP_KEY_SIGN (per-host exhaustion) per S5.2 §3&lt;/li>&lt;li>identity-init registers bootstrap group (HUMAN_USER not yet present; hardware-key signature substitutes per S5.1 §5.2.1)&lt;/li>&lt;li>policy-compiler loads constitutional policy bundle (signed)&lt;/li>&lt;li>Each stage emits FOREVER FIRST_BOOT_OPERATION receipt (escape clause for INV-012 RecoveryRequiredForSystemMutation; per S2.3 §26.2.2 W9 update)&lt;/li>&lt;li>At stage exit: firstboot marker written; is_first_boot flag self-extinguishes atomically across all subject sessions&lt;/li>&lt;li>System transitions to RecoveryMode = NORMAL&lt;/li>&lt;/ol>&lt;p>&lt;strong>Invariants threaded:&lt;/strong> INV-001 (no L5), INV-004 (recovery boundary), INV-012 (system mutation gating — first-boot exception), INV-018 (vault no leak), INV-005 (FOREVER evidence per stage).&lt;/p>"/>
          <ownedAbstractCapabilityRealizations xsi:type="org.polarsys.capella.core.data.interaction:AbstractCapabilityRealization"
              id="bd341cf3-8418-4d17-ae8f-e427ea66bf4a" targetElement="#176eeef6-8c59-53a9-a203-c1814e940ea3"/>
          <ownedAbstractCapabilityRealizations xsi:type="org.polarsys.capella.core.data.interaction:AbstractCapabilityRealization"
              id="208d82df-51b6-443b-90ce-9196bbedbfc1" targetElement="#3d1d2cb2-91ed-5113-ba39-7396bc45fe4b"/>
          <ownedAbstractCapabilityRealizations xsi:type="org.polarsys.capella.core.data.interaction:AbstractCapabilityRealization"
