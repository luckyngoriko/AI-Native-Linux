        <ownedCapabilities xsi:type="org.polarsys.capella.core.data.ctx:Capability"
            id="e464b4d1-6158-5034-b3d0-94524bf00529" name="S0.3 — MVP Golden Path Contract (Rev.2)"
            description="&lt;p>&lt;strong>Layer.&lt;/strong> XX&lt;/p>&lt;p>&lt;strong>Status.&lt;/strong> REAL (initial; written 2026-05-09; E1 evidence — file exists; structural contract complete; trace walks every layer of the L0..L10 stack)&lt;/p>&lt;p>&lt;strong>Schema package.&lt;/strong> n/a — this contract is a trace and acceptance test, not a service&lt;/p>&lt;p>&lt;strong>Source.&lt;/strong> XX_Cross_Cutting/03_mvp_golden_path.md&lt;/p>">
          <ownedScenarios xsi:type="org.polarsys.capella.core.data.interaction:Scenario"
              id="90541b58-50f3-4969-83c0-c12d0939d627" name="Golden path — typed action lifecycle end-to-end"
              description="&lt;p>&lt;strong>Source:&lt;/strong> XX_Cross_Cutting/03_mvp_golden_path.md&lt;/p>&lt;p>&lt;strong>Participants:&lt;/strong> HUMAN_USER operator, AIOS Capability Runtime (S10.1), Policy Kernel (S2.3), Sandbox Composer (S3.2), Verification Engine (S2.4), Evidence Log (S3.1), Renderer (S7.6).&lt;/p>&lt;p>&lt;strong>Flow:&lt;/strong>&lt;/p>&lt;ol>&lt;li>operator submits typed ActionEnvelope (act_&amp;lt;ulid&amp;gt;) per S0.1&lt;/li>&lt;li>Capability Runtime validates envelope, normalizes subject (S2.3 §7)&lt;/li>&lt;li>Policy Kernel evaluates → ALLOW (no hard-deny fires, no approval gate)&lt;/li>&lt;li>Sandbox composed per S3.2 most-restrictive-wins&lt;/li>&lt;li>Adapter dispatches typed action (ISOLATED_SANDBOX per S10.1)&lt;/li>&lt;li>Verification probes run per S2.4 closed grammar&lt;/li>&lt;li>Evidence Log appends 5-receipt chain: ACTION_RECEIVED → POLICY_DECISION → EXECUTION_STARTED → EXECUTION_COMPLETED → VERIFICATION_RESULT&lt;/li>&lt;li>Renderer surfaces result + CHROME zone (INV-020) shows action_id + evidence link&lt;/li>&lt;/ol>&lt;p>&lt;strong>Invariants exercised:&lt;/strong> INV-002 (AI proposes never executes — if subject is_ai, branches to AI scenario), INV-005 (append-only), INV-014 (no proof no completion), INV-020 (trust indicators visible).&lt;/p>"/>
          <ownedAbstractCapabilityRealizations xsi:type="org.polarsys.capella.core.data.interaction:AbstractCapabilityRealization"
